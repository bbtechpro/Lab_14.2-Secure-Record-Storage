{
  "info": {
    "name": "Lab_14.2 Secure Record Storage",
    "description": "Postman collection to test authentication, note creation, and ownership authorization.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "tokenB",
      "value": ""
    },
    {
      "key": "noteId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"userA\",\n  \"email\": \"userA@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register returns 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set('token', response.token);",
              "pm.collectionVariables.set('userId', response.user._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Login User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"userA@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set('token', response.token);",
              "pm.collectionVariables.set('userId', response.user._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Register User B",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"userB\",\n  \"email\": \"userB@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register B returns 201', function () {",
              "    pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login User B",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"userB@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login B returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set('tokenB', response.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Note as User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"User A Note\",\n  \"content\": \"This note belongs to user A.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Create note returns 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const response = pm.response.json();",
              "pm.collectionVariables.set('noteId', response._id);",
              "pm.test('Note owner matches user A', function () {",
              "    pm.expect(response.user).to.eql(pm.collectionVariables.get('userId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Notes as User A",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get all notes returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.test('At least one note exists for user A', function () {",
              "    pm.expect(response.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Note by ID as User A",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Get note by ID returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "pm.test('Retrieved note belongs to user A', function () {",
              "    pm.expect(response.user).to.eql(pm.collectionVariables.get('userId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Note as User A",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"User A Note (Updated)\",\n  \"content\": \"Updated content for user A.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update note returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Attempt Get Note as User B",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tokenB}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized get note returns 403', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Attempt Update Note as User B",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{tokenB}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Bad Update\",\n  \"content\": \"This should not be allowed.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized update returns 403', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Attempt Delete Note as User B",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{tokenB}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized delete returns 403', function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Note as User A",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/notes/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "notes",
            "{{noteId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete note returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
